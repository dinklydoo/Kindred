Grammar

    0 $accept: module KEOF

    1 module: definitions KEOF

    2 definitions: ε
    3            | definitions definition

    4 definition: function_def
    5           | struct_def
    6           | enum_def

    7 opt_types: ε
    8          | types

    9 types: type
   10      | types COMMA type

   11 non_function_type: literal_type
   12                  | list_type
   13                  | nominal_type

   14 type: non_function_type
   15     | func_type

   16 literal_type: T_CHAR
   17             | T_BOOL
   18             | int_lit_type
   19             | float_lit_type

   20 int_lit_type: T_INT
   21             | T_LONG

   22 float_lit_type: T_FLOAT
   23               | T_DOUBLE

   24 list_type: SQ_LBRA type SQ_RBRA

   25 func_type: LBRA opt_types RBRA PROD type

   26 nominal_type: LABEL

   27 opt_params: ε
   28           | params

   29 params: param
   30       | params COMMA param

   31 param: LABEL TSEP type

   32 function_def: FUNC LABEL LBRA opt_params RBRA TSEP type program

   33 fields: field
   34       | fields COMMA field

   35 field: LABEL TSEP type

   36 struct_def: STRUCT LABEL LBRA fields RBRA

   37 evar: LABEL

   38 evars: evar
   39      | evars COMMA evar

   40 enum_def: ENUM LABEL LBRA evars RBRA

   41 program: helpers branch_expr

   42 branch_expr: return_expr
   43            | guard_expr
   44            | case_expr

   45 guard_expr: CASE OF TSEP guards PEND

   46 guards: guard
   47       | guards COMMA guard

   48 guard: BAR value_expr ARROW program
   49      | BAR ELSE ARROW program

   50 case_expr: MARK value_expr OF TSEP patterns PEND

   51 patterns: pattern_branch
   52         | patterns COMMA pattern_branch

   53 pattern_branch: pattern ARROW program

   54 literal: char_lit
   55        | int_lit
   56        | float_lit
   57        | bool_lit
   58        | enum_lit
   59        | list_pattern
   60        | struct_lit

   61 pattern: literal
   62        | DEFAULT

   63 enum_lit: LABEL

   64 struct_lit: NIL
   65           | LABEL C_LBRA list_pattern_lit C_RBRA

   66 list_pattern: SQ_LBRA SQ_RBRA
   67             | list_lit
   68             | string_lit
   69             | size_patterns

   70 string_lit: STRING

   71 list_lit: SQ_LBRA list_pattern_lit SQ_RBRA

   72 list_pattern_lit: literal
   73                 | list_pattern_lit COMMA literal

   74 size_patterns: LABEL TSEP LABEL
   75              | size_patterns TSEP LABEL

   76 return_expr: RETURN value_expr

   77 helpers: ε
   78        | helpers helper_expr

   79 helper_expr: assign_expr
   80            | print_expr
   81            | read_expr

   82 print_expr: PRINT LBRA value_expr RBRA

   83 read_expr: LABEL TSEP non_function_type ASSGN READ LBRA RBRA

   84 assign_expr: LABEL TSEP LBRA opt_params RBRA PROD type LBRA program RBRA
   85            | LABEL TSEP non_function_type ASSGN value_expr

   86 int_lit: INT

   87 float_lit: FLOAT

   88 bool_lit: TRUE
   89         | FALSE

   90 char_lit: CHAR

   91 bool_op: BOR
   92        | BAND

   93 comp_op: CEQ
   94        | CNEQ
   95        | CGT
   96        | CLT
   97        | CGEQ
   98        | CLEQ

   99 bitwise_op: LAND
  100           | BAR
  101           | LXOR

  102 shift_op: LSL
  103         | LSR

  104 additive_op: ADD
  105            | SUB
  106            | CONCAT

  107 mult_op: MUL
  108        | DIV
  109        | MOD
  110        | FLR

  111 unary_op: BNOT
  112         | LNEG
  113         | SUB

  114 nominal_expr: LABEL

  115 list_expr: empty_list
  116          | list_con
  117          | string_lit

  118 empty_list: SQ_LBRA SQ_RBRA

  119 list_con: SQ_LBRA expr_list SQ_RBRA

  120 expr_list: value_expr
  121          | expr_list COMMA value_expr

  122 call_expr: LABEL LBRA RBRA
  123          | LABEL LBRA expr_list RBRA

  124 struct_expr: LABEL C_LBRA expr_list C_RBRA

  125 value_expr: bool_expr

  126 bool_expr: comp_expr
  127          | bool_expr bool_op comp_expr

  128 comp_expr: bitwise_expr
  129          | bitwise_expr comp_op bitwise_expr

  130 bitwise_expr: shift_expr
  131             | bitwise_expr bitwise_op shift_expr

  132 shift_expr: additive_expr
  133           | shift_expr shift_op additive_expr

  134 additive_expr: mult_expr
  135              | additive_expr additive_op mult_expr

  136 mult_expr: pow_expr
  137          | mult_expr mult_op pow_expr

  138 pow_expr: unary_expr
  139         | unary_expr POW pow_expr

  140 unary_expr: postfix_expr
  141           | unary_op postfix_expr

  142 postfix_expr: literal_expr
  143             | postfix_expr SQ_LBRA value_expr SQ_RBRA
  144             | postfix_expr DOT LABEL

  145 literal_expr: int_lit
  146             | float_lit
  147             | char_lit
  148             | bool_lit
  149             | list_expr
  150             | nominal_expr
  151             | call_expr
  152             | struct_expr
  153             | LBRA value_expr RBRA


