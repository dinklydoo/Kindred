enum example (
    FOO, BAR, HELLO, WORLD
)

struct Tree (
    left : Tree,
    right : Tree,
    val : int
)

func get_val(node: Tree): int
    mark node of:
        nil => return 0,
        default => return node.val
    ;

func factorial(n: int): int
    case of:
        | (n > 1) => return n * factorial(n-1),
        | else => return 1
    ;

func atoi(r: [char], n: int): int
    mark r of:
        [] => return n,
        r:rs =>
            mark r of:
                '-' => return -atoi(rs, n),
                default => return atoi(rs, (r - '0') + 10*n)
            ;
        ;

func main(): int
    r:[char] = read()
    n:int = atoi(r, 0)
    print(factorial(n))
    return 1