@ Factorial Example Code in Kindred

func factorial(n: int): int
    mark n of:
        | (n > 1) => return n * factorial(n-1),
        | else => return 1
    ;

func atoi(r: [char], n: int): int
    case r of:
        [] => return n,
        r:rs =>
            case r of:
                '-' => return -atoi(rs, n),
                default => return atoi(rs, (r - '0') + 10*n)
            ;
        ;

func main(): int
    r:[char] = read()
    n:int = atoi(r)
    print(factorial(n))
    return 1