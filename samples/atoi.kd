func atoi(r: [char], n: int): int
    mark r of:
        [] => return n,
        x:xs =>
            mark x of:
                '-' => return -atoi(xs, n),
                default => return atoi(xs, (x-'0') + 10*n)
            ;
        ;

func main(:): int
    r:[char] = read()
    n:int = atoi(r, 0)
    print(n)
    return 0